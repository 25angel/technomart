{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": "data/**"
    }
  },
  "routes": [
    {
      "src": "/api/(health|store|orders|chat)",
      "dest": "/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
